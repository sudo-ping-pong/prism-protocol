{
  "name": "@sudo-ping-pong/prism-protocol",
  "version": "0.1.1",
  "description": "Shared protocol types for Prism DevTools",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudo-ping-pong/prism-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/sudo-ping-pong/prism-protocol/issues"
  },
  "homepage": "https://github.com/sudo-ping-pong/prism-protocol#readme",
  "keywords": [
    "prism",
    "devtools",
    "protocol",
    "react-native",
    "expo",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
